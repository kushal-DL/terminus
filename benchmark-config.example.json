{
  "_comment": "Sample benchmark config — copy and edit. Run with: python -m terminus --benchmark benchmark-config.example.json",

  "models": [
    {
      "name": "GPT-4o",
      "provider": "openai",
      "endpoint": "https://api.openai.com/v1",
      "model": "gpt-4o",
      "api_key_env": "OPENAI_API_KEY"
    }
  ],

  "games_per_matchup": 3,
  "max_turns": 100,
  "speed_multiplier": 5,
  "seed_mode": "fixed",
  "base_seed": 42,

  "opponents": ["random", "greedy", "balanced"],

  "weight_preset": "balanced",
  "enable_state_probes": false,

  "output_dir": "./benchmark-results",
  "export_html": true,
  "export_json": true
}
